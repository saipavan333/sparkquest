# Keep the image small & build context clean
.git
.github
.gitignore
.venv
venv
__pycache__
*.pyc
.pytest_cache
.ruff_cache
.mypy_cache
.coverage
htmlcov

# Research artifacts not needed at runtime (context only — the image copies just
# what the Dockerfile COPYs, so docs/handbook + data/README.md must stay reachable)
paper
benchmarks
tests
# NOTE: do NOT exclude `docs` or `*.md` — the Dockerfile copies docs/handbook
# (the in-app handbook) and the build fails with "/docs/handbook: not found" otherwise.

# Local Spark / data scratch
spark-warehouse
metastore_db
derby.log
checkpoints
data/raw

# Env & secrets
.env
kaggle.json
wandb
