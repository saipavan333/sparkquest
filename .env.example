# ---- SparkQuest configuration (copy to .env and fill in) ----

# App
SPARKQUEST_HOST=0.0.0.0
SPARKQUEST_PORT=7860
SPARKQUEST_ENV=development          # development | production

# Code execution sandbox limits
SQ_EXEC_TIMEOUT_SECONDS=25          # max wall-clock per submission
SQ_EXEC_MAX_OUTPUT_CHARS=20000      # truncate stdout/stderr beyond this
SQ_SPARK_MASTER=local[2]            # Spark master for learner sessions

# AI Tutor — choose a provider, or leave blank for the built-in rule-based tutor
# Supported: anthropic | openai | huggingface | none
SQ_TUTOR_PROVIDER=none
SQ_TUTOR_MODEL=
SQ_TUTOR_API_KEY=
# For huggingface provider only (Inference API / TGI endpoint URL):
SQ_TUTOR_HF_ENDPOINT=

# Experiment tracking (benchmarks only)
WANDB_API_KEY=
WANDB_PROJECT=sparkquest-benchmarks
WANDB_ENTITY=

# Kaggle (data acquisition only) — or place kaggle.json at ~/.kaggle/kaggle.json
KAGGLE_USERNAME=
KAGGLE_KEY=
